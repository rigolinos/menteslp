---
---

<div class="space-y-8 md:space-y-12 pb-12 w-full">
  <div class="border-b border-white/10 pb-8 md:pb-12">
    <p class="font-serif text-[#D4AF37] italic text-xl md:text-2xl mb-2">A Obra Literária</p>
    <h3 class="font-serif text-5xl md:text-7xl text-white tracking-tight">Mentes que Inspiram</h3>
    <p class="text-slate-400 mt-6 max-w-2xl leading-relaxed text-base md:text-lg">
      O livro que originou o movimento. Uma leitura profunda e tocante sobre a arte do acolhimento, educação inclusiva e as descobertas de uma maternidade atípica.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-center">
    <!-- Book 3D Mockup Frame -->
    <div class="md:col-span-5 flex justify-center perspective-[1000px]">
      <div id="book-3d-wrapper" class="relative group w-64 h-96 transition-transform duration-200 ease-out preserve-3d">
        <!-- Ambient Glow -->
        <div class="absolute -inset-4 bg-gradient-to-r from-[#D4AF37]/40 to-transparent rounded-lg blur-2xl opacity-20 group-hover:opacity-50 transition duration-1000"></div>
        
        <!-- Book spine / cover representation -->
        <div id="book-3d-element" class="relative w-full h-full bg-gradient-to-br from-[#0B0D12] to-[#1A202C] rounded-r-xl border-y border-r border-[#D4AF37]/40 shadow-[20px_20px_40px_rgba(0,0,0,0.8)] flex flex-col justify-between p-8 overflow-hidden transform-gpu preserve-3d">
          <div class="absolute top-0 left-0 w-3 h-full bg-gradient-to-r from-black/80 to-[#D4AF37]/20 border-r border-[#D4AF37]/20 shadow-[inset_-2px_0_4px_rgba(0,0,0,0.5)]"></div>
          
          <div class="space-y-5 pt-6 pl-5 relative z-10 translate-z-[20px]">
            <span class="text-[10px] uppercase tracking-widest text-[#D4AF37] font-mono font-bold">Vanessa Sanceverino Esteves</span>
            <h4 class="font-serif text-4xl text-white font-light italic leading-tight drop-shadow-md">Mentes<br><span class="text-[#D4AF37] font-normal not-italic">que</span><br>Inspiram</h4>
          </div>

          <div class="pl-5 pb-5 relative z-10 translate-z-[20px]">
            <img src="/img/Logo principal-clean.svg" alt="Mentes Logo" class="w-20 opacity-50 drop-shadow-md">
          </div>
          
          <!-- Book Pages Illusion (Right edge) -->
          <div class="absolute top-1 bottom-1 right-0 w-2 bg-gradient-to-l from-white/80 to-slate-300/40 rounded-r shadow-inner"></div>
        </div>
      </div>
    </div>

    <!-- Book Details & Specs -->
    <div class="md:col-span-7 space-y-8">
      <div class="space-y-4">
        <h4 class="text-2xl font-bold text-white">Sobre a obra</h4>
        <p class="text-slate-300 text-sm md:text-base leading-relaxed">
          Nesta obra, Vanessa Sanceverino Esteves abre as portas de sua experiência pessoal e profissional para discutir a fundo o impacto do acolhimento nas escolas e famílias. O livro aborda a maternidade atípica não sob uma ótica de limitação, mas como um convite revolucionário ao amor, empatia e repensar das estruturas educacionais vigentes.
        </p>
        <p class="text-slate-300 text-sm md:text-base leading-relaxed">
          Leitura recomendada para educadores, terapeutas, pais e qualquer pessoa que queira se aprofundar na arte de enxergar e potencializar o ser humano em sua singularidade.
        </p>
      </div>

      <!-- Book chapters / highlights (Bento style) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
        <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/10 transition-colors">
          <svg class="w-6 h-6 text-[#D4AF37] mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h5 class="text-white text-sm font-bold mb-1">Inclusão Humanizada</h5>
          <p class="text-slate-400 text-xs leading-snug">Metodologias práticas e reais para aplicação imediata.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/10 transition-colors">
          <svg class="w-6 h-6 text-[#D4AF37] mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <h5 class="text-white text-sm font-bold mb-1">Relatos Inéditos</h5>
          <p class="text-slate-400 text-xs leading-snug">Casos de sucesso inspiradores que trazem esperança.</p>
        </div>
      </div>

      <!-- Purchase buttons (Touch targets 48px min) -->
      <div class="flex flex-col sm:flex-row items-center gap-4 pt-6">
        <a 
          href="https://amazon.com.br/mock-mentes-livro" 
          target="_blank" 
          rel="noopener" 
          class="flex items-center justify-center w-full sm:w-auto px-8 h-14 bg-[#D4AF37] text-black font-semibold rounded-full hover:bg-white hover:text-black transition-all duration-300 shadow-lg shadow-[#D4AF37]/20"
        >
          Comprar Físico (Amazon)
        </a>
        <a 
          href="https://eduzz.com/mock-mentes-livro" 
          target="_blank" 
          rel="noopener" 
          class="flex items-center justify-center w-full sm:w-auto px-8 h-14 bg-transparent text-white border border-white/20 font-semibold rounded-full hover:bg-white hover:text-black hover:border-white transition-all duration-300"
        >
          Versão Digital (Eduzz)
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .preserve-3d {
    transform-style: preserve-3d;
  }
  .translate-z-\[20px\] {
    transform: translateZ(20px);
  }
</style>

<script is:inline>
  // Book 3D Mouse Parallax (Desktop Only)
  const bookWrapper = document.getElementById('book-3d-wrapper');
  
  if (bookWrapper) {
    const isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
    
    if (!isTouchDevice) {
      bookWrapper.addEventListener('mousemove', (e) => {
        const rect = bookWrapper.getBoundingClientRect();
        const x = e.clientX - rect.left; // x position within the element.
        const y = e.clientY - rect.top;  // y position within the element.
        
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        // Calculate rotation based on distance from center
        let rotateX = ((y - centerY) / centerY) * -30; // Max 30 deg raw
        let rotateY = ((x - centerX) / centerX) * 30;  // Max 30 deg raw
        
        // CLAMP CONSTRAINT: Limit to ±20 degrees as requested by the engineer
        rotateX = Math.max(-20, Math.min(20, rotateX));
        rotateY = Math.max(-20, Math.min(20, rotateY));
        
        bookWrapper.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });

      bookWrapper.addEventListener('mouseleave', () => {
        bookWrapper.style.transform = `rotateX(0deg) rotateY(0deg)`;
      });
    }
  }
</script>
