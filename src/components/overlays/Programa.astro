---
import episodes from '../../data/episodes.json';
---

<div class="space-y-12">
  <div class="border-b border-[#D4AF37]/20 pb-6">
    <p class="font-serif text-[#D4AF37] italic text-xl mb-2">Mentes que Inspiram</p>
    <h3 class="font-serif text-4xl md:text-6xl text-white">O Programa</h3>
    <p class="text-slate-400 mt-4 max-w-2xl leading-relaxed text-sm md:text-base">
      Um espaço de diálogos profundos com especialistas, educadores e pessoas que estão transformando a realidade da educação e da inclusão. Assista e inspire-se.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {episodes.map((ep) => (
      <div class="group relative bg-[#0B0D12] rounded-xl border border-white/5 overflow-hidden hover:border-[#D4AF37]/30 transition-all duration-500 hover:shadow-[0_10px_30px_rgba(212,175,55,0.05)]">
        <!-- Thumbnail Wrap -->
        <div class="relative aspect-video w-full overflow-hidden bg-slate-900">
          <img 
            src={ep.thumbnail} 
            alt={ep.guest} 
            class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
          
          <!-- Episode badge -->
          <span class="absolute top-4 left-4 bg-[#D4AF37] text-black font-mono font-bold text-xs px-2.5 py-1 rounded">
            EPISÓDIO {ep.episode}
          </span>

          <!-- Duration -->
          <span class="absolute bottom-4 right-4 text-xs font-medium text-slate-300 bg-black/60 px-2 py-0.5 rounded font-mono">
            {ep.duration}
          </span>
        </div>

        <!-- Info -->
        <div class="p-6 space-y-4">
          <div class="space-y-1">
            <span class="text-xs font-semibold text-[#D4AF37]/80 uppercase tracking-wider">{ep.guest}</span>
            <h4 class="font-serif text-xl text-white group-hover:text-[#D4AF37] transition-colors duration-300 leading-tight">
              {ep.title}
            </h4>
          </div>
          
          <p class="text-slate-400 text-xs leading-relaxed line-clamp-3">
            {ep.description}
          </p>

          <a 
            href={`https://youtube.com/watch?v=${ep.youtubeId}`} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-xs font-semibold text-white group-hover:text-[#D4AF37] transition-colors pt-2"
          >
            <span>Assistir no YouTube</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
          </a>
        </div>
      </div>
    ))}
  </div>

  <div class="text-center pt-8">
    <a 
      href="https://youtube.com/@ProgramaMentesqueInspiram" 
      target="_blank" 
      rel="noopener" 
      class="inline-flex items-center gap-3 px-8 py-3 bg-[#D4AF37] text-black font-semibold rounded-full hover:bg-white hover:text-black transition-all duration-300 shadow-lg shadow-[#D4AF37]/10"
    >
      <span>Canal Oficial no YouTube</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
    </a>
  </div>
</div>
