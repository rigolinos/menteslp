---
import episodes from '../../data/episodes.json';

// Destacar o último episódio da Temporada 2
const latestEpisode = episodes[episodes.length - 1];
const season1 = episodes.filter(ep => ep.season === 1);
const season2 = episodes.filter(ep => ep.season === 2 && ep.id !== latestEpisode.id);
---

<div class="space-y-8 md:space-y-16 pb-12 w-full">
  <!-- Hero Section interno -->
  <div class="relative border-b border-white/10 pb-8 md:pb-12">
    <!-- Quick Links (Touch friendly: min-h 48px) -->
    <div class="flex flex-wrap gap-4 mb-6">
      <a href="https://youtube.com/@ProgramaMentesqueInspiram" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 h-12 bg-white/5 hover:bg-white/10 text-white rounded-full transition-all text-sm font-medium border border-white/10 backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-red-500"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="white"/></svg>
        YouTube
      </a>
      <a href="#" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 h-12 bg-white/5 hover:bg-white/10 text-white rounded-full transition-all text-sm font-medium border border-white/10 backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-[#1DB954]"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.625.625 0 0 1-.858.207c-2.348-1.434-5.304-1.76-8.784-.964a.626.626 0 1 1-.288-1.218c3.818-.87 7.07-.496 9.723 1.117a.625.625 0 0 1 .207.858zm1.22-2.736a.78.78 0 0 1-1.073.257c-2.68-1.645-6.786-2.128-9.965-1.166a.782.782 0 1 1-.453-1.5c3.67-1.114 8.2-.58 11.233 1.284a.78.78 0 0 1 .258 1.125zm.116-2.852C14.73 9.006 8.54 8.78 4.975 9.863a.975.975 0 1 1-.564-1.862c4.103-1.242 10.96-.98 14.736 1.265a.976.976 0 1 1-1.225 1.57z"/></svg>
        Spotify
      </a>
    </div>

    <p class="font-serif text-[#D4AF37] italic text-xl md:text-2xl mb-2">Mentes que Inspiram</p>
    <h3 class="font-serif text-5xl md:text-7xl text-white tracking-tight">O Programa</h3>
    <p class="text-slate-400 mt-6 max-w-2xl leading-relaxed text-base md:text-lg">
      Um espaço de diálogos profundos com especialistas, educadores e pessoas que estão transformando a realidade da educação e da inclusão. Assista, ouça e inspire-se.
    </p>
  </div>

  <!-- DESTAQUE GLOBAL (Hero Bento + Spotify Widget) -->
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 pb-8 md:pb-12 border-b border-white/5">
    
    <!-- Latest Episode (Hero Bento) -->
    {latestEpisode && (
      <a href={`https://youtube.com/watch?v=${latestEpisode.youtubeId}`} target="_blank" rel="noopener noreferrer" class="bento-item group relative md:col-span-12 lg:col-span-8 bg-[#0B0D12] rounded-3xl overflow-hidden border border-white/5 hover:border-[#D4AF37]/30 transition-all duration-500 h-[400px] md:h-[500px] flex flex-col justify-end">
        <div class="absolute inset-0 w-full h-full">
          <img src={latestEpisode.thumbnail} alt={latestEpisode.guest} class="w-full h-full object-cover filter grayscale-[0.5] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
        </div>
        
        <div class="relative z-10 p-6 md:p-10 w-full md:w-3/4">
          <span class="inline-flex items-center h-8 px-3 rounded bg-[#D4AF37] text-black font-mono font-bold text-xs mb-4">
            ÚLTIMO EPISÓDIO LANÇADO
          </span>
          <h4 class="font-serif text-3xl md:text-5xl text-white group-hover:text-[#D4AF37] transition-colors duration-300 leading-tight mb-3">
            {latestEpisode.title} <span class="text-slate-300 text-2xl md:text-4xl">({latestEpisode.guest})</span>
          </h4>
          <div class="flex items-center gap-3 text-white font-medium mt-6">
            <span class="flex items-center justify-center w-12 h-12 rounded-full bg-white/10 group-hover:bg-[#D4AF37] group-hover:text-black transition-colors backdrop-blur-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
            </span>
            <span class="text-sm tracking-wide">Assistir agora</span>
          </div>
        </div>
      </a>
    )}

    <!-- Spotify Widget Mini (Bento) -->
    <div class="bento-item hidden lg:flex lg:col-span-4 bg-[#0B0D12] rounded-3xl border border-white/5 p-8 flex-col justify-between hover:border-[#1DB954]/50 transition-colors group relative overflow-hidden">
      <!-- Decorator Background -->
      <div class="absolute -right-10 -top-10 w-48 h-48 bg-[#1DB954] opacity-5 blur-3xl rounded-full group-hover:opacity-10 transition-opacity"></div>
      
      <div class="relative z-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-[#1DB954] mb-6"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.625.625 0 0 1-.858.207c-2.348-1.434-5.304-1.76-8.784-.964a.626.626 0 1 1-.288-1.218c3.818-.87 7.07-.496 9.723 1.117a.625.625 0 0 1 .207.858zm1.22-2.736a.78.78 0 0 1-1.073.257c-2.68-1.645-6.786-2.128-9.965-1.166a.782.782 0 1 1-.453-1.5c3.67-1.114 8.2-.58 11.233 1.284a.78.78 0 0 1 .258 1.125zm.116-2.852C14.73 9.006 8.54 8.78 4.975 9.863a.975.975 0 1 1-.564-1.862c4.103-1.242 10.96-.98 14.736 1.265a.976.976 0 1 1-1.225 1.57z"/></svg>
        <h4 class="text-3xl font-serif text-white mb-3">Podcast Oficial</h4>
        <p class="text-slate-400 text-sm leading-relaxed">Escute nossos bate-papos no carro, no trabalho ou onde estiver. Em breve disponível no Spotify.</p>
      </div>
      <a href="#" target="_blank" rel="noopener" class="relative z-10 flex items-center justify-center w-full h-14 bg-[#1DB954] text-black font-semibold rounded-full hover:bg-[#1ed760] transition-colors mt-6">
        Ouvir no Spotify
      </a>
    </div>
  </div>

  <!-- TABS UI PREMIUM (GSAP) -->
  <div class="relative mb-8 mt-4 w-full" id="tabs-container">
    <!-- Trilho Base -->
    <div class="absolute bottom-0 left-0 w-full h-[1px] bg-white/10"></div>
    <!-- Linha Ativa Dourada -->
    <div id="active-indicator" class="absolute bottom-0 left-0 h-[2px] bg-[#E0B356] origin-left z-10 w-0"></div>

    <div class="flex items-center gap-8 md:gap-12 w-full">
      <div id="tab-s1" class="season-tab cursor-pointer text-xl md:text-2xl font-serif text-[#E0B356] transition-colors py-3 px-2 md:px-4 select-none origin-center inline-block">
        Temporada 1
      </div>
      <div id="tab-s2" class="season-tab cursor-pointer text-xl md:text-2xl font-serif text-zinc-500 transition-colors py-3 px-2 md:px-4 select-none origin-center inline-block">
        Temporada 2
      </div>
    </div>
  </div>

  <!-- TEMPORADA 1 GRID -->
  <div id="grid-s1" class="season-grid grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">
    {season1.map((ep) => (
      <a href={`https://youtube.com/watch?v=${ep.youtubeId}`} target="_blank" rel="noopener noreferrer" class="bento-item group md:col-span-6 lg:col-span-4 bg-[#0B0D12] rounded-2xl border border-white/5 overflow-hidden hover:border-[#E0B356]/30 transition-all duration-500 hover:bg-white/[0.02]">
        <div class="relative aspect-video w-full overflow-hidden bg-slate-900">
          <img src={ep.thumbnail} alt={ep.guest} class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <span class="absolute bottom-3 right-3 text-white font-mono font-medium text-xs tracking-wider drop-shadow-md bg-black/40 backdrop-blur-sm px-2 py-1 rounded">
            EP {ep.episode}
          </span>
        </div>
        <div class="p-6">
          <h4 class="font-serif text-xl md:text-2xl text-white group-hover:text-[#E0B356] transition-colors duration-300 leading-tight mb-3">
            {ep.title} <span class="text-slate-400 text-lg">({ep.guest})</span>
          </h4>
        </div>
      </a>
    ))}
  </div>

  <!-- TEMPORADA 2 GRID -->
  <div id="grid-s2" class="season-grid grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 hidden">
    {season2.map((ep) => (
      <a href={`https://youtube.com/watch?v=${ep.youtubeId}`} target="_blank" rel="noopener noreferrer" class="bento-item group md:col-span-6 lg:col-span-4 bg-[#0B0D12] rounded-2xl border border-white/5 overflow-hidden hover:border-[#E0B356]/30 transition-all duration-500 hover:bg-white/[0.02]">
        <div class="relative aspect-video w-full overflow-hidden bg-slate-900">
          <img src={ep.thumbnail} alt={ep.guest} class="w-full h-full object-cover filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <span class="absolute bottom-3 right-3 text-white font-mono font-medium text-xs tracking-wider drop-shadow-md bg-black/40 backdrop-blur-sm px-2 py-1 rounded">
            EP {ep.episode}
          </span>
        </div>
        <div class="p-6">
          <h4 class="font-serif text-xl md:text-2xl text-white group-hover:text-[#E0B356] transition-colors duration-300 leading-tight mb-3">
            {ep.title} <span class="text-slate-400 text-lg">({ep.guest})</span>
          </h4>
        </div>
      </a>
    ))}
  </div>

</div>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const tabS1 = document.getElementById('tab-s1');
    const tabS2 = document.getElementById('tab-s2');
    const gridS1 = document.getElementById('grid-s1');
    const gridS2 = document.getElementById('grid-s2');
    const indicator = document.getElementById('active-indicator');
    const tabsContainer = document.getElementById('tabs-container');

    if (!tabS1 || !tabS2 || !indicator || !tabsContainer) return;

    let activeSeason = 1;

    // Inicializa a posição do indicador
    function updateIndicator(targetTab, animate = true) {
      const containerRect = tabsContainer.getBoundingClientRect();
      const tabRect = targetTab.getBoundingClientRect();

      // Calcula a posição relativa ao contêiner
      const offsetLeft = tabRect.left - containerRect.left;
      const width = tabRect.width;

      if (animate) {
        gsap.to(indicator, {
          x: offsetLeft,
          width: width,
          duration: 0.4,
          ease: "power3.out"
        });
      } else {
        gsap.set(indicator, { x: offsetLeft, width: width });
      }
    }

    // Chamada inicial (sem animação para assentar na tela)
    setTimeout(() => updateIndicator(tabS1, false), 50);
    window.addEventListener('resize', () => {
      updateIndicator(activeSeason === 1 ? tabS1 : tabS2, false);
    });

    function selectTab(season, targetElement) {
      if (season === activeSeason) return; // Não faz nada se já estiver ativa
      activeSeason = season;

      // Desliza a linha
      updateIndicator(targetElement, true);

      if (season === 1) {
        // Cores
        tabS1.classList.replace('text-zinc-500', 'text-[#E0B356]');
        tabS2.classList.replace('text-[#E0B356]', 'text-zinc-500');

        // Mostra Grid 1 com um leve fade e esconder Grid 2
        gridS2.classList.add('hidden');
        gridS1.classList.remove('hidden');
        gsap.fromTo(gridS1, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" });

      } else {
        // Cores
        tabS2.classList.replace('text-zinc-500', 'text-[#E0B356]');
        tabS1.classList.replace('text-[#E0B356]', 'text-zinc-500');

        // Mostra Grid 2
        gridS1.classList.add('hidden');
        gridS2.classList.remove('hidden');
        gsap.fromTo(gridS2, { opacity: 0, y: 10 }, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" });
      }
    }

    // Micro-interações de clique (Pointer Events)
    [tabS1, tabS2].forEach((tab, index) => {
      const season = index + 1;

      // Touch / Clicar afunda o botão
      tab.addEventListener('pointerdown', () => {
        gsap.to(tab, { scale: 0.95, duration: 0.1 });
      });

      // Soltar ativa e faz efeito mola
      tab.addEventListener('pointerup', () => {
        gsap.to(tab, { scale: 1, duration: 0.4, ease: "back.out(2)" });
        selectTab(season, tab);
      });

      // Cancelar caso arraste para fora
      tab.addEventListener('pointerleave', () => {
        gsap.to(tab, { scale: 1, duration: 0.4, ease: "back.out(2)" });
      });
    });
  });
</script>
