---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

import EcosystemHub from '../components/EcosystemHub.astro';
import Programa from '../components/overlays/Programa.astro';
import Cursos from '../components/overlays/Cursos.astro';
import Livro from '../components/overlays/Livro.astro';
import Eventos from '../components/overlays/Eventos.astro';
import Consultoria from '../components/overlays/Consultoria.astro';
import MediaKit from '../components/overlays/MediaKit.astro';
import HeroLogo from '../components/HeroLogo.astro';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentes que Inspiram — Vanessa Sanceverino Esteves</title>
    <meta name="description" content="Mentes que Inspiram — Um ecossistema de conversas, educação, inclusão e transformação social com Vanessa Sanceverino Esteves.">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Spline 3D Viewer -->
    <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.5/build/spline-viewer.js"></script>

    <!-- GSAP -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <!-- Lucide Icons -->
    <script is:inline src="https://unpkg.com/lucide@latest"></script>

    <!-- Vanilla CSS (Legacy) - Global, not scoped, to preserve Scrollytelling exactly as it was -->
    <link rel="stylesheet" href="/legacy.css">

    <ViewTransitions />
</head>
<body class="loading">

<!-- PRELOADER PREMIUM -->
<div id="preloader">
    <div class="preloader__bg"></div>
    <div class="preloader__content">
        <div class="preloader__logo-wrap">
            <img src="/img/Logo principal svg.svg" alt="Mentes que Inspiram" class="preloader__logo">
        </div>
        <div class="preloader__progress">
            <div class="preloader__bar"></div>
        </div>
        <p class="preloader__caption">Preparando a experiência</p>
    </div>
</div>

<!-- Canvas de fundo animado -->
<canvas id="mentes-canvas" transition:persist="canvas"></canvas>

<!-- Altura virtual para controlar o scroll das cenas -->
<div id="scroll-driver"></div>

<!-- Scroll Tracker Lateral Premium -->
<nav id="scroll-tracker" aria-label="Progresso da narrativa">
    <div class="tracker-rail">
        <div class="tracker-dot active" data-scene="0"><span class="tracker-dot__label">Início</span></div>
        <div class="tracker-dot" data-scene="1"><span class="tracker-dot__label">A Mulher</span></div>
        <div class="tracker-dot" data-scene="2"><span class="tracker-dot__label">O Programa</span></div>
        <div class="tracker-dot" data-scene="3"><span class="tracker-dot__label">O Ecossistema</span></div>
        <div class="tracker-dot" data-scene="4"><span class="tracker-dot__label">As Marcas</span></div>
        <div class="tracker-dot" data-scene="5"><span class="tracker-dot__label">O Convite</span></div>
    </div>
</nav>

<!-- Wrapper das cenas em overlay fixo -->
<div id="story-wrapper">

    <!-- CENA 0: Hero -->
    <section class="story-scene" data-scene="0" id="scene-hero">
        <div class="scene-inner scene-center">
            <div class="scene-logo-wrap w-full max-w-[600px] mx-auto">
                <HeroLogo />
            </div>
            <div class="scene-tagline">
                <p class="tagline-line" id="tagline-1"></p>
                <p class="tagline-line" id="tagline-2"></p>
            </div>
            <div class="scroll-hint">
                <div class="scroll-hint__line"></div>
                <span>scroll</span>
            </div>
        </div>
    </section>

    <!-- CENA 1: A Mulher -->
    <section class="story-scene" data-scene="1" id="scene-woman">
        <!-- Video 2 em P&B como fundo da cena -->
        <video class="scene-bg-video" autoplay muted loop playsinline>
            <source src="/img/2.mp4" type="video/mp4">
        </video>
        <div class="scene-inner scene-split">
            <div class="scene-text-col">
                <span class="scene-num">01 /</span>
                <h2 class="scene-title text-3xl md:text-5xl">Vanessa Sanceverino<br><em>Esteves.</em></h2>
                <h3 class="text-[#D4AF37] font-serif italic text-lg md:text-xl mt-4">"Uma mente brilhante, um coração atento."</h3>
                <p class="scene-body mt-4 text-slate-300 leading-relaxed max-w-md text-sm md:text-base hidden md:block">
                    Com mais de dez anos de experiência em liderança pedagógica, Vanessa construiu sua carreira fundamentada na gestão de excelência e na comunicação de impacto. Sua atuação une o rigor técnico da educação à sensibilidade necessária para abordar temas de grande relevância social e urgência por inclusão.
                </p>
                <div class="scene-traits mt-4 md:mt-6">
                    <span class="trait">Liderança Educacional</span>
                    <span class="trait">Comunicação com Propósito</span>
                    <span class="trait">Visão Inclusiva & Maternidade Atípica</span>
                </div>
            </div>
            <div class="scene-photo-col">
                <div class="scene-photo-frame">
                    <img src="/img/mentes10.jpeg" alt="Vanessa Sanceverino Esteves" class="scene-photo">
                    <div class="scene-photo-vignette"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CENA 2: O Programa -->
    <section class="story-scene" data-scene="2" id="scene-program">
        <div class="scene-inner scene-split">
            <div class="scene-text-col">
                <span class="scene-num">02 /</span>
                <h2 class="scene-title">O <em>Programa.</em></h2>
                <p class="scene-body mt-4 text-slate-300 leading-relaxed max-w-md text-sm md:text-base hidden md:block">
                    Um espaço de entrevistas voltado a conversas que geram valor, consciência e impacto. Com linguagem sofisticada e acessível, aborda temas contemporâneos conectando especialistas, educadores e histórias inspiradoras.
                </p>
                <div class="scene-traits mt-4 md:mt-6">
                    <span class="trait">Educação e Inovação</span>
                    <span class="trait">Inclusão e Diversidade</span>
                    <span class="trait">Desenvolvimento Humano</span>
                    <span class="trait">Liderança e Inspiração</span>
                </div>
            </div>
            <div class="scene-video-col">
                <div class="scene-video-frame">
                    <video id="program-video" autoplay muted loop playsinline>
                        <source src="/img/1.mp4" type="video/mp4">
                    </video>
                </div>
            </div>
        </div>
    </section>

    <!-- CENA 4: O Ecossistema (Substituído pelo novo EcosystemHub) -->
    <EcosystemHub />

    <!-- Overlays Container (Approach B Hybrid) -->
    <div id="overlays-container" class="fixed inset-0 z-50 pointer-events-none opacity-0 bg-[#050608]/95 backdrop-blur-md flex flex-col px-4 md:px-8 h-[100dvh] overflow-y-auto overscroll-contain">
        <!-- Botão Fechar -->
        <button id="close-overlay" class="fixed top-6 right-6 md:top-8 md:right-8 text-white hover:text-[#D4AF37] transition-colors pointer-events-auto z-[60] bg-white/5 hover:bg-white/10 backdrop-blur-xl p-3 md:p-2 rounded-full border border-white/10">
            <i data-lucide="x" class="w-6 h-6 md:w-8 md:h-8"></i>
        </button>

        <!-- Conteúdos Estáticos de cada Overlay -->
        <div id="overlay-content" class="max-w-5xl w-full mx-auto pt-24 pb-32 text-white flex-grow relative">
            <div id="overlay-content-programa" class="overlay-section hidden w-full">
                <Programa />
            </div>
            <div id="overlay-content-cursos" class="overlay-section hidden w-full">
                <Cursos />
            </div>
            <div id="overlay-content-livro" class="overlay-section hidden w-full">
                <Livro />
            </div>
            <div id="overlay-content-eventos" class="overlay-section hidden w-full">
                <Eventos />
            </div>
            <div id="overlay-content-consultoria" class="overlay-section hidden w-full">
                <Consultoria />
            </div>
            <div id="overlay-content-mediakit" class="overlay-section hidden w-full">
                <MediaKit />
            </div>
        </div>
    </div>

    <!-- CENA 4: As Marcas -->
    <section class="story-scene" data-scene="4" id="scene-sponsors">
        <div class="scene-inner scene-center">
            <span class="scene-num">04 /</span>
            <h2 class="scene-title">Marcas que acreditam<br><em>no poder da inclusão.</em></h2>
            <p class="scene-body font-serif italic text-slate-300">
                Uma aliança estratégica com instituições que<br>
                desenham o futuro junto conosco.
            </p>
            
            <div class="sponsors-grid mt-12 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-10">
                <a href="https://www.instagram.com/bruckihomebeauty" target="_blank" rel="noopener noreferrer" class="sponsor-card opacity-0 transform translate-y-8 w-48 h-28 md:w-64 md:h-36 rounded-xl overflow-hidden shadow-[0_0_20px_rgba(212,175,55,0.05)] border border-white/5 transition-all duration-700 hover:scale-105 hover:border-[#E0B356]/50">
                    <img src="/img/BRUCKI.jpeg" alt="Brucki" class="w-full h-full object-cover object-center scale-110">
                </a>
                <a href="https://www.akomacristais.com.br/" target="_blank" rel="noopener noreferrer" class="sponsor-card opacity-0 transform translate-y-8 w-48 h-28 md:w-64 md:h-36 rounded-xl overflow-hidden shadow-[0_0_20px_rgba(212,175,55,0.05)] border border-white/5 transition-all duration-700 delay-100 hover:scale-105 hover:border-[#E0B356]/50">
                    <img src="/img/Akoma.jpeg" alt="Akoma" class="w-full h-full object-contain object-center">
                </a>
                <a href="https://lifeconassessoria.com.br/" target="_blank" rel="noopener noreferrer" class="sponsor-card opacity-0 transform translate-y-8 w-48 h-28 md:w-64 md:h-36 rounded-xl overflow-hidden shadow-[0_0_20px_rgba(212,175,55,0.05)] border border-white/5 transition-all duration-700 delay-200 hover:scale-105 hover:border-[#E0B356]/50">
                    <img src="/img/Life%20Con.jpeg" alt="Life Con" class="w-full h-full object-contain object-center">
                </a>
            </div>
        </div>
    </section>

    <!-- CENA 5: O Convite -->
    <section class="story-scene" data-scene="5" id="scene-cta">
        <div class="scene-inner scene-center">
            <h2 class="scene-title scene-title--cta">Faça parte<br><em>dessa história.</em></h2>
            <div class="scene-ctas">
                <button data-overlay-trigger="programa" class="cta-pill cta-pill--gold" id="cta-episodes">Assista aos Episódios</button>
                <button data-overlay-trigger="mediakit" class="cta-pill cta-pill--outline" id="cta-partner">Seja uma Marca Parceira</button>
                <button data-overlay-trigger="eventos" class="cta-pill cta-pill--outline" id="cta-invite">Convide Vanessa</button>
            </div>
        </div>
    </section>

</div><!-- /story-wrapper -->

<!-- Noise overlay -->
<div class="noise"></div>

<!-- Carregamento do JS Vanilla adaptado para ViewTransitions -->
<script is:inline src="/main.js"></script>
<script is:inline src="/scripts/overlays.js"></script>
<script is:inline>
    // Repassa o ciclo de vida do Astro para reativar o GSAP caso haja transição de tela
    document.addEventListener('astro:page-load', () => {
        if(typeof window.initScrollytelling === 'function') {
            window.initScrollytelling();
        }
        lucide.createIcons();
    });
</script>
</body>
</html>
